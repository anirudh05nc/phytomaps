            "source": [
                "import shutil\n",
                "import random\n",
                "from pathlib import Path\n",
                "\n",
                "OUT_DIR = BASE_DIR / \"unified_dataset\"\n",
                "if OUT_DIR.exists():\n",
                "    shutil.rmtree(OUT_DIR)\n",
                "\n",
                "splits = [\"train\", \"val\", \"test\"]\n",
                "for split in splits:\n",
                "    (OUT_DIR / \"images\" / split).mkdir(parents=True, exist_ok=True)\n",
                "    (OUT_DIR / \"labels\" / split).mkdir(parents=True, exist_ok=True)\n",
                "\n",
                "def process_and_filter_dataset(dataset_files, source_tag):\n",
                "    valid_pairs = []\n",
                "    outliers_removed = 0\n",
                "    \n",
                "    for img_path in dataset_files['images']:\n",
                "        # Fix the Blueberry_1 nested path matching\n",
                "        new_path_str = str(img_path).replace('images', 'labels').replace('images\\\\\\\\', 'labels\\\\\\\\')\n",
                "        lbl_path = Path(new_path_str).with_suffix('.txt')\n",
                "        \n",
                "        if not lbl_path.exists():\n",
                "            continue\n",
                "            \n",
                "        with open(lbl_path, \"r\") as f:\n",
                "            lines = f.readlines()\n",
                "            \n",
                "        if len(lines) == 0:\n",
                "            outliers_removed += 1 \n",
                "            continue\n",
                "            \n",
                "        normalized_lines = []\n",
                "        for line in lines:\n",
                "            parts = line.strip().split()\n",
                "            if not parts: continue\n",
                "            try:\n",
                "                class_id = int(parts[0])\n",
                "            except ValueError:\n",
                "                continue\n",
                "            \n",
                "            # Normalize class IDs for Unified format\n",
                "            if source_tag == \"BB1\":\n",
                "                normalized_id = class_id\n",
                "            elif source_tag == \"BB2\":\n",
                "                if class_id == 0:\n",
                "                    normalized_id = 0\n",
                "                elif class_id == 3:\n",
                "                    normalized_id = 1\n",
                "                else:\n",
                "                    continue \n",
                "            \n",
                "            normalized_lines.append(f\"{normalized_id} \" + \" \".join(parts[1:]) + \"\\n\")\n",
                "            \n",
                "        if not normalized_lines:\n",
                "            outliers_removed += 1\n",
                "            continue\n",
                "            \n",
                "        valid_pairs.append({\n",
                "            'img': img_path, \n",
                "            'lbl': lbl_path,\n",
                "            'source': source_tag,\n",
                "            'normalized_lines': normalized_lines\n",
                "        })\n",
                "        \n",
                "    print(f\"[{source_tag}] Kept {len(valid_pairs)} valid pairs. Skipped {outliers_removed} files with no valid labels.\")\n",
                "    return valid_pairs\n",
                "\n",
                "print(\"Processing datasets...\")\n",
                "bb1_valid = process_and_filter_dataset(blue_1_files, \"BB1\")\n",
                "bb2_valid = process_and_filter_dataset(blue_2_files, \"BB2\")\n",
                "\n",
                "all_valid_data = bb1_valid + bb2_valid\n",
                "print(f\"\\\\nTotal clean, merged dataset size: {len(all_valid_data)}\")\n"
            ]
        },
        {
            "cell_type": "markdown",
