                "from ultralytics import YOLO\n",
                "\n",
                "# Build & Define the Model\n",
                "print(\"Building YOLOv8 model...\")\n",
                "model = YOLO('yolov8s.pt')\n",
                "\n",
                "#Train the Model\n",
                "print(\"Starting training on unified_dataset...\")\n",
                "results = model.train(\n",
                "    data='unified_dataset/data.yaml', # Points to the dataset\n",
                "    epochs=50,                        # Number of times it will look through the entire dataset\n",
                "    imgsz=640,                        # Standard image size it will squeeze the pictures into\n",
                "    batch=16,                         # How many images it processes at the exact same time\n",
                "    name='blueberry_detector_v1',      # The name of the folder \n",
                "    hsv_s = 0.5,\n",
                "    hsv_v = 0.5,\n",
                "    fliplr = 0.5,\n",
                "    mosaic = 1.0\n",
                ")\n",
                "\n",
                "print(\"Training complete! The model is saved and ready to use.\")\n"
            ]
        },
