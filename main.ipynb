            "source": [
                "from ultralytics import YOLO\n",
                "\n",
                "# 1. Load trained model \n",
                "trained_model = YOLO(\"runs/detect/blueberry_detector_v12/weights/best.pt\")\n",
                "\n",
                "# 2. Pick an image\n",
                "test_image_path = \"unified_dataset/images/test/BB1_P1000092-JPG_6_png.rf.f79595206c1f50f56982bef23db1ae04.jpg\"\n",
                "\n",
                "# 3. Run the image through the model\n",
                "results = trained_model.predict(test_image_path, conf=0.25,save = True,name = \"Blueberry_prediction\") # conf=0.25 means it must be 25% confident\n",
                "\n",
                "# 4. Count the fruits\n",
                "result = results[0]\n",
                "detected_classes = result.boxes.cls.cpu().numpy() # list of all detected class IDs (0s and 1s)\n",
                "\n",
                "unripe_count = (detected_classes == 0).sum()\n",
                "ripe_count = (detected_classes == 1).sum()\n",
                "total_fruits = len(detected_classes)\n",
                "\n",
                "print(f\"--- Detection Results ---\")\n",
                "print(f\"Total Fruits Detected: {total_fruits}\")\n",
                "print(f\"Ripe Blueberries: {ripe_count}\")\n",
                "print(f\"Unripe Blueberries: {unripe_count}\")"
            ]
        },
